# Server config
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=your_database_url_here

# JWT
JWT_SECRET=your_jwt_secret_key_here

# ThingsBoard config
THINGSBOARD_HOST=demo.thingsboard.io
THINGSBOARD_PORT=1883

THINGSBOARD_ACCESS_TOKEN=your_device_access_token_here

TB_TELEMETRY_TEMPERATURE=temperature
TB_TELEMETRY_HUMIDITY=humidity
TB_TELEMETRY_GAS=gas_value

TB_RPC_SET_TEMP_LED=setTempLed
TB_RPC_SET_HUMI_LED=setHumiLed
TB_RPC_GET_TEMP_LED=getTempLed
TB_RPC_GET_HUMI_LED=getHumiLed